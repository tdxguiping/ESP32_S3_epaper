CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/v2/16m.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions/v2/16m.csv"
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_EXAMPLE_MOUNT_SD_CARD=y
CONFIG_EXAMPLE_USE_SDMMC_HOST=y
CONFIG_EXAMPLE_PIN_SDMMC_CLK=39
CONFIG_EXAMPLE_PIN_CMD=41
CONFIG_EXAMPLE_PIN_D0=40
CONFIG_EXAMPLE_PIN_D1=1
CONFIG_EXAMPLE_PIN_D2=2
CONFIG_EXAMPLE_PIN_D3=38
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=255
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
# Keep ESP-IDF Bluetooth disabled while USER_BLE_ENABLE is 0.
# This avoids unused BT/WiFi coexistence allocation during WiFi startup.
# CONFIG_BT_ENABLED is not set
CONFIG_ESP_WIFI_ENABLED=y
# Enable PSRAM because migrated upload/cast requests can carry nearly 1 MB image bodies.
# 中文：开启 PSRAM，因为移植的 upload/cast 请求可能携带接近 1 MB 的图片数据包。
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=512
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=65536

# Use ESP32-S3 native USB Serial/JTAG as the primary console.
# This keeps ESP_LOG/printf off UART0 so UART0 can be used by CH583.
# CONFIG_ESP_CONSOLE_UART_DEFAULT is not set
# CONFIG_ESP_CONSOLE_USB_CDC is not set
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
# CONFIG_ESP_CONSOLE_UART_CUSTOM is not set
# CONFIG_ESP_CONSOLE_NONE is not set
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
CONFIG_USJ_ENABLE_USB_SERIAL_JTAG=y
# Keep USB Serial/JTAG stable by blocking automatic Light-sleep while a host is connected.
# 连接 PC 时阻止自动 Light-sleep，优先保证 USB console 和数据传输稳定。
CONFIG_USJ_NO_AUTO_LS_ON_CONNECTION=y
CONFIG_ESPTOOLPY_MONITOR_BAUD=921600
# CONFIG_ESP_WIFI_STA_DISCONNECTED_PM_ENABLE is not set
CONFIG_PM_ENABLE=y
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y
CONFIG_FREERTOS_IDLE_TIME_BEFORE_SLEEP=3
CONFIG_PM_POWER_DOWN_CPU_IN_LIGHT_SLEEP=y
CONFIG_PM_PROFILING=y
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_ESP_TIMER_SHOW_EXPERIMENTAL=y
# CONFIG_ESP_TIMER_TASK_AFFINITY_CPU0 is not set
CONFIG_ESP_TIMER_TASK_AFFINITY_CPU1=y
# CONFIG_ESP_TIMER_ISR_AFFINITY_CPU0 is not set
CONFIG_ESP_TIMER_ISR_AFFINITY_CPU1=y
