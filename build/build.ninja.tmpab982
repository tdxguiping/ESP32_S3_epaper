  COMMAND = C:\Windows\system32\cmd.exe /C "cd /D H:\AI2\file_serving\build\esp-idf\riscv && C:\Espressif\tools\cmake\3.30.2\bin\cmake-gui.exe -SH:\AI2\file_serving -BH:\AI2\file_serving\build"
